# =====================================================
# BROU Chargeback Demo — Variables de entorno
# Copiar este archivo a `.env` y completar.
# =====================================================

# --- Gemini (Google AI Studio) ---
# https://aistudio.google.com → Get API key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- Supabase Cloud ---
# https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# UUID v4 fijo del usuario de la demo. Generá uno con:
#   python -c "import uuid; print(uuid.uuid4())"
DEMO_USER_ID=

# --- Langfuse (opcional) ---
# https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# CORS origin permitido para el frontend
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend (Next.js) ---
# Esto va en frontend/.env.local también:
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
